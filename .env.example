# Anthropic (instruction parsing). App still works without it via keyword fallback.
ANTHROPIC_API_KEY=

# Auth — set AUTH_DISABLED=true for local dev without Google OAuth
AUTH_DISABLED=true
AUTH_SECRET=            # npx auth secret   (or: openssl rand -base64 32)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_URL=               # e.g. https://abbode-cropper-xxxxx-ue.a.run.app  (prod only)
