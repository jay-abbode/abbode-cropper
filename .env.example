# Anthropic (instruction parsing). App still works without it via keyword fallback.
ANTHROPIC_API_KEY=

# Auth — set AUTH_DISABLED=true to run without Google OAuth (local dev, or a
# first Vercel deploy just to see it live).
AUTH_DISABLED=true
AUTH_SECRET=            # npx auth secret   (or: openssl rand -base64 32)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# AUTH_URL is optional on Vercel (trustHost is on). Set it to your production
# URL, e.g. https://abbode-cropper.vercel.app, once the domain is known.
AUTH_URL=
